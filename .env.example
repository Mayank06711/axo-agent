# Redis
REDIS_URL=redis://localhost:6380/0

# LLM Providers (set the one you want to use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-nano

# LLM Defaults (openai | azure | anthropic | google)
DEFAULT_LLM_PROVIDER=azure
DEFAULT_LLM_MODEL=gpt-4.1-nano

# Frontend
FRONTEND_URL=http://localhost:5173

# Agent Config
MAX_TOOL_CALLS_PER_TASK=5

# Storage (redis or postgres)
STORAGE_BACKEND=redis
